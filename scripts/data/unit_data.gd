static func get_unit_info(unit_id: String) -> Dictionary:
	if buildings.has(unit_id):
		return buildings[unit_id]
	if units.has(unit_id):
		return units[unit_id]
	return {}

static func can_build(unit_id: String, built_buildings) -> bool:
	var info = get_unit_info(unit_id)
	if info.is_empty():
		return false
	var prereq = info.get("prerequisite", "")
	if prereq.is_empty():
		return true
	return prereq in built_buildings
